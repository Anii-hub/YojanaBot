# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
env/
.venv/
ENV/
.env_backup

# ── Secrets / Environment variables ───────────────────────────────────────────
# NEVER commit .env — it contains API keys!
.env
.env.local
.env.*.local
*.key

# ── Django ────────────────────────────────────────────────────────────────────
db.sqlite3
db.sqlite3-journal
staticfiles/
media/
*.log

# ── Data files ────────────────────────────────────────────────────────────────
# Raw downloaded PDFs (large binary files)
data/raw/pdfs/
# Downloaded scheme JSON (regenerated by Step 1)
data/raw/schemes_step1.json
# ChromaDB binary vector index — committed so Render never has to rebuild at runtime
# (Rebuild OOM-kills the free-tier 512 MB worker). To regenerate locally:
#   python -m rag_pipeline.vector_store build --chunks data/processed/scheme_chunks_step2.json
# data/chroma/          <-- INTENTIONALLY un-ignored, keep committed
data/chroma_sample/
# Evaluation output (regenerated by Step 8)
evaluation/eval_results.json

# Keep sample/example data files (small, illustrative)
!data/raw/schemes_step1.sample.json
!data/processed/scheme_chunks_step2.sample.json
!data/processed/scheme_chunks_step2.json
!data/sample_profiles/

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Testing / Coverage ────────────────────────────────────────────────────────
.coverage
.pytest_cache/
htmlcov/
.tox/

# ── Jupyter / IPython ─────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Misc ──────────────────────────────────────────────────────────────────────
*.bak
*.tmp
results/

# ── Render / deployment ───────────────────────────────────────────────────────
# HuggingFace model cache (stored on persistent disk, never commit)
data/.cache/

# Keep deployment files committed
!build.sh
!render.yaml

